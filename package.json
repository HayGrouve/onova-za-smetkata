{
  "name": "onova-za-smetkata",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "prototype:host-paid": "vite dev --port 3000 --open /prototype/host-paid-presentation?variant=A",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "preflight": "pnpm run test && node scripts/check-pwa-icons.mjs && pnpm run build",
    "check-icons": "node scripts/check-pwa-icons.mjs",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "deploy": "pnpm run preflight && npx convex deploy",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "generate-icons": "node scripts/generate-pwa-icons.mjs",
    "generate-og-image": "node scripts/generate-og-image.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.94",
    "@convex-dev/react-query": "0.1.0",
    "@sentry/react": "^10.64.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.27",
    "@tanstack/router-plugin": "^1.132.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.120",
    "heic2any": "^0.0.4",
    "jose": "^6.2.3",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.20.0",
    "jsdom": "^28.1.0",
    "nitro": "3.0.260610-beta",
    "prettier": "^3.8.1",
    "sharp": "^0.35.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ],
    "patchedDependencies": {
      "vaul@1.1.2": "patches/vaul@1.1.2.patch"
    }
  }
}
