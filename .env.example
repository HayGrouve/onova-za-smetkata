# ── Local development (.env.local) ──────────────────────────────
CONVEX_DEPLOYMENT=your-dev-deployment-name
VITE_CONVEX_URL=https://your-dev-deployment.convex.cloud

# ── Convex Dashboard → Settings → Environment Variables ─────────
# Required for receipt OCR:
# GEMINI_API_KEY=your-google-ai-key
# Optional model override:
# GEMINI_MODEL=gemini-3.5-flash

# Optional — local dev auth bypass (Convex Dashboard → dev deployment only):
# DEV_MODE=true
# Enables the dev Password provider when set on the Convex deployment (Dashboard or `npx convex env set DEV_MODE true`).
# Never set on production (coordinated-warbler-782).
# The Vite dev server auto-signs in.

# Required for Convex Auth (generate keys via `npx @convex-dev/auth`):
# SITE_URL=http://localhost:3000
# JWT_PRIVATE_KEY=...
# JWKS=...

# Google OAuth (Google Cloud Console → OAuth client):
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...
# Redirect URI (dev): https://<dev-deployment>.convex.site/api/auth/callback/google
# Redirect URI (prod): https://<prod-deployment>.convex.site/api/auth/callback/google

# Magic link email (Resend):
# AUTH_RESEND_KEY=...
# AUTH_RESEND_FROM=Онова за сметката <noreply@yourdomain.com>

# ── Vercel → Project Settings → Environment Variables ───────────
# Required for production frontend build:
# VITE_CONVEX_URL=https://your-prod-deployment.convex.cloud

# Optional — client error tracking (Sentry):
# VITE_SENTRY_DSN=https://...@sentry.io/...

# Optional — used for QR/link copy when window.origin unavailable at build time:
# VITE_APP_ORIGIN=https://onova-za-smetkata.com

# ── Production Convex auth checklist ────────────────────────────
# Set on the PRODUCTION deployment (not just dev):
# SITE_URL=https://onova-za-smetkata.com
# JWT_PRIVATE_KEY=... (from `npx @convex-dev/auth`)
# JWKS=...
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...
# AUTH_RESEND_KEY=...
# AUTH_RESEND_FROM=... (verified domain in Resend)
# NEVER set DEV_MODE=true on production
